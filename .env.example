# ============================================================
# open-meteo-warehouse — variáveis de ambiente
# Copie este arquivo para `.env` e ajuste os valores.
# ============================================================

# --- Banco de dados (Supabase) ---
# Pegue a string em: Supabase > Project Settings > Database > Connection string (Session pooler)
# Formato:
DATABASE_URL=postgresql://postgres.<projeto-ref>:<senha>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Open-Meteo API ---
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive
OPEN_METEO_TIMEOUT_SECONDS=30

# --- Ingestão ---
# Intervalo padrão de coleta histórica inicial (YYYY-MM-DD)
INGESTION_START_DATE=2020-01-01
# Arquivo com as localidades a coletar
INGESTION_LOCATIONS_FILE=locations.json

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- Scheduler (modo --daemon da ingestão) ---
SCHEDULER_CRON_HOUR=3
SCHEDULER_CRON_MINUTE=0
SCHEDULER_LOOKBACK_DAYS=7

# --- Logging ---
LOG_LEVEL=INFO
